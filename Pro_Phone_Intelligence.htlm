<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pro Phone Intelligence</title>

<style>
body {
    margin:0;
    font-family: system-ui;
    background: linear-gradient(135deg,#0f172a,#020617);
    color:white;
    display:flex;
    align-items:center;
    justify-content:center;
    height:100vh;
}
.app {
    width:380px;
    background:#111827;
    border-radius:16px;
    padding:25px;
    box-shadow:0 20px 40px rgba(0,0,0,.5);
}
h2 { text-align:center; margin-bottom:15px; }

input {
    width:100%;
    padding:12px;
    border-radius:10px;
    border:none;
    margin-bottom:10px;
    font-size:15px;
    background:#020617;
    color:white;
}
button {
    width:100%;
    padding:12px;
    border:none;
    border-radius:10px;
    background:#3b82f6;
    color:white;
    font-size:16px;
    cursor:pointer;
}
button:hover { background:#2563eb; }

.result {
    margin-top:15px;
    padding:12px;
    border-radius:10px;
    background:#020617;
    font-size:14px;
}

.badge {
    display:inline-block;
    padding:4px 8px;
    border-radius:6px;
    font-size:12px;
    margin-top:5px;
}

.valid { background:#16a34a; }
.invalid { background:#dc2626; }
</style>
</head>

<body>

<div class="app">
<h2>📡 Phone Intelligence PRO</h2>

<input id="phone" placeholder="+923409777222">
<button onclick="analyze()">Analyze</button>

<div class="result" id="output">Enter a number...</div>
</div>

<!-- Embedded minimal libphonenumber logic -->
<script>

/*
Lightweight internal parser (simulating libphonenumber behavior)
*/

function cleanNumber(num){
    return num.replace(/[^\d+]/g,'');
}

function validateNumber(num){
    return /^\+\d{10,15}$/.test(num);
}

function detectCountry(num){
    const map = {
        "+92":"Pakistan",
        "+91":"India",
        "+1":"USA/Canada",
        "+44":"United Kingdom",
        "+971":"UAE",
        "+966":"Saudi Arabia"
    };
    for(let code in map){
        if(num.startsWith(code)) return map[code];
    }
    return "Unknown";
}

function detectRegionPK(num){
    if(!num.startsWith("+92")) return null;

    const area = num.slice(3,5);

    const regions = {
        "21":"Karachi",
        "42":"Lahore",
        "51":"Islamabad/Rawalpindi",
        "61":"Multan",
        "91":"Peshawar"
    };

    return regions[area] || "Unknown Region";
}

function detectCarrierPK(num){
    if(!num.startsWith("+92")) return "N/A";

    const prefix = num.slice(3,6);

    const carriers = {
        "300":"Jazz","301":"Jazz","302":"Jazz","303":"Jazz",
        "310":"Zong","311":"Zong","312":"Zong",
        "320":"Warid","321":"Warid",
        "330":"Ufone","331":"Ufone",
        "340":"Telenor","341":"Telenor","342":"Telenor"
    };

    return carriers[prefix] || "Unknown";
}

function formatNumber(num){
    return num.replace(/(\+\d{2})(\d{3})(\d{7})/, "$1 $2 $3");
}

function analyze(){
    let input = document.getElementById("phone").value;
    let num = cleanNumber(input);

    const output = document.getElementById("output");

    if(!validateNumber(num)){
        output.innerHTML = `
        <span class="badge invalid">Invalid</span><br>
        Please enter a valid international number
        `;
        return;
    }

    const country = detectCountry(num);
    const region = detectRegionPK(num);
    const carrier = detectCarrierPK(num);
    const formatted = formatNumber(num);

    output.innerHTML = `
    <span class="badge valid">Valid Number</span><br><br>

    <b>📞 Number:</b> ${formatted}<br>
    <b>🌍 Country:</b> ${country}<br>
    ${region ? `<b>📍 Region:</b> ${region}<br>` : ""}
    <b>📡 Carrier:</b> ${carrier}<br>

    <br><small>⚡ Offline Intelligence Engine</small>
    `;
}

/* PWA Support */
if('serviceWorker' in navigator){
    navigator.serviceWorker.register(URL.createObjectURL(new Blob([`
        self.addEventListener('install',e=>self.skipWaiting());
        self.addEventListener('fetch',e=>{});
    `],{type:'text/javascript'})));
}

</script>

</body>
</html>
